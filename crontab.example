# Crontab para limpieza automática de archivos temporales
# YouTube MP3 Downloader

# Limpiar archivos temporales cada 5 minutos
*/5 * * * * find /tmp/youtube_downloads -type f -mmin +5 -delete 2>/dev/null

# Alternativa: Usar el script de limpieza cada hora
# 0 * * * * /home/emilio/Escritorio/desarrollador/servicio\ descargas/cleanup.sh >> /var/log/youtube-cleanup.log 2>&1

# Limpiar logs antiguos cada día a las 3 AM
# 0 3 * * * find /var/log/youtube-downloader/ -name "*.log" -mtime +7 -delete 2>/dev/null

# Para instalar este crontab:
# 1. Editar crontab: crontab -e
# 2. Copiar las líneas que necesites
# 3. Guardar y salir
